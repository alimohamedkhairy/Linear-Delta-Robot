<?xml version="1.0"?>
<robot xmlns:xacro="http://www.ros.org/wiki/xacro">

    <xacro:arg name="is_sim" default="true"/>

    <xacro:unless value="$(arg is_sim)">

        <link name="extruder_stepper_motor_virtual_link">
            <inertial>
                <mass value="0.05"/>
                <origin xyz="0 0 0"/>
                <inertia ixx="0.0001" ixy="0" ixz="0" iyy="0.0001" iyz="0" izz="0.0001"/>
            </inertial>
        </link>

        <joint name="extrusion_joint" type="continuous">
            <parent link="end_effector_link"/>
            <child link="extruder_stepper_motor_virtual_link"/>
            <origin xyz="0 0 0" rpy="0 0 0"/>
            <axis xyz="0 0 1"/>
            <limit effort="10" velocity="1.0"/>
        </joint>

    </xacro:unless>

    <ros2_control name="LinearDeltaRobotHardware" type="system">
        <hardware>
            <xacro:if value="$(arg is_sim)">
                <plugin>gz_ros2_control/GazeboSimSystem</plugin>
            </xacro:if>
            <xacro:unless value="$(arg is_sim)">
                <plugin>linear_delta_hardware/LinearDeltaHardwarePlugin</plugin>
            </xacro:unless>
        </hardware>
        <joint name="rod_0_to_dynamic_stabilizer_0_joint">
            <xacro:if value="$(arg is_sim)">
                <command_interface name="effort"/>
            </xacro:if>
            <xacro:unless value="$(arg is_sim)">
                <command_interface name="position"/>
            </xacro:unless>
            <state_interface name="position"/>
            <xacro:if value="$(arg is_sim)">
                <state_interface name="velocity"/>
            </xacro:if>
        </joint>
        <joint name="rod_1_to_dynamic_stabilizer_1_joint">
            <xacro:if value="$(arg is_sim)">
                <command_interface name="effort"/>
            </xacro:if>
            <xacro:unless value="$(arg is_sim)">
                <command_interface name="position"/>
            </xacro:unless>
            <state_interface name="position"/>
            <xacro:if value="$(arg is_sim)">
                <state_interface name="velocity"/>
            </xacro:if>
        </joint>
        <joint name="rod_2_to_dynamic_stabilizer_2_joint">
            <xacro:if value="$(arg is_sim)">
                <command_interface name="effort"/>
            </xacro:if>
            <xacro:unless value="$(arg is_sim)">
                <command_interface name="position"/>
            </xacro:unless>
            <state_interface name="position"/>
            <xacro:if value="$(arg is_sim)">
                <state_interface name="velocity"/>
            </xacro:if>
        </joint>
        <xacro:unless value="$(arg is_sim)">
            <joint name="extrusion_joint">
                <command_interface name="position"/>
                <state_interface name="position"/>
            </joint>
        </xacro:unless> 
    </ros2_control>

</robot>