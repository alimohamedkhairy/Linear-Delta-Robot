<?xml version="1.0"?>
<robot xmlns:xacro="http://www.ros.org/wiki/xacro">

<xacro:macro name="connector" params="id">

    <link name="connector_${id}_0_link">

        <visual>
            <origin xyz="0.0 0.0 ${connector_z}" rpy="0.0 0.0 0.0"/>
            <geometry>
                <mesh filename="package://linear_delta_description/meshes/connector.stl" scale="0.001 0.001 0.001"/>
            </geometry>
            <material name="color_14"/>
        </visual>

        <collision>
            <origin xyz="0.0 0.0 ${connector_z}" rpy="0.0 0.0 0.0"/>
            <geometry>
                <mesh filename="package://linear_delta_description/meshes/connector.stl" scale="0.001 0.001 0.001"/>
            </geometry>
        </collision>

        <inertial>
            <origin xyz="0.0 0.0 ${connector_z}" rpy="0.0 0.0 0.0"/>
            <mass value="0.2"/>
            <inertia ixx="0.0008" ixy="0" ixz="0" iyy="0.0008" iyz="0" izz="0.00001"/>
        </inertial>

    </link>

    <link name="connector_${id}_1_link">

        <visual>
            <origin xyz="0.0 0.0 ${connector_z}" rpy="0.0 0.0 0.0"/>
            <geometry>
                <mesh filename="package://linear_delta_description/meshes/connector.stl" scale="0.001 0.001 0.001"/>
            </geometry>
            <material name="color_14"/>
        </visual>

        <collision>
            <origin xyz="0.0 0.0 ${connector_z}" rpy="0.0 0.0 0.0"/>
            <geometry>
                <mesh filename="package://linear_delta_description/meshes/connector.stl" scale="0.001 0.001 0.001"/>
            </geometry>
        </collision>

        <inertial>
            <origin xyz="0.0 0.0 ${connector_z}" rpy="0.0 0.0 0.0"/>
            <mass value="0.2"/>
            <inertia ixx="0.0008" ixy="0" ixz="0" iyy="0.0008" iyz="0" izz="0.00001"/>
        </inertial>

    </link>

    <link name="upper_virtual_${id}_0_0_link">
        <inertial>
            <mass value="0.001"/>
            <inertia ixx="1e-6" ixy="0" ixz="0" iyy="1e-6" iyz="0" izz="1e-6"/>
        </inertial>
    </link>

    <link name="upper_virtual_${id}_0_1_link">
        <inertial>
            <mass value="0.001"/>
            <inertia ixx="1e-6" ixy="0" ixz="0" iyy="1e-6" iyz="0" izz="1e-6"/>
        </inertial>
    </link>

    <joint name="upper_ball_screw_${id}_to_upper_virtual_${id}_0_0_joint" type="continuous">
        <origin xyz="${connector_x} ${connector_y} 0.0" rpy="0.0 0.0 0.0"/>
        <parent link="upper_ball_screw_${id}_0_link"/>
        <child link="upper_virtual_${id}_0_0_link"/>
        <axis xyz="1 0 0"/>
        <limit effort="10.0" velocity="3.0"/>
        <dynamics damping="0.1" friction="0.01"/>
    </joint>

    <joint name="upper_ball_screw_${id}_to_upper_virtual_${id}_0_1_joint" type="continuous">
        <origin xyz="${connector_x} ${connector_y} 0.0" rpy="0.0 0.0 0.0"/>
        <parent link="upper_ball_screw_${id}_1_link"/>
        <child link="upper_virtual_${id}_0_1_link"/>
        <axis xyz="1 0 0"/>
        <limit effort="10.0" velocity="3.0"/>
        <dynamics damping="0.1" friction="0.01"/>
    </joint>
        
    <link name="upper_virtual_${id}_1_0_link">
        <inertial>
            <mass value="0.001"/>
            <inertia ixx="1e-6" ixy="0" ixz="0" iyy="1e-6" iyz="0" izz="1e-6"/>
        </inertial>
    </link>

    <link name="upper_virtual_${id}_1_1_link">
        <inertial>
            <mass value="0.001"/>
            <inertia ixx="1e-6" ixy="0" ixz="0" iyy="1e-6" iyz="0" izz="1e-6"/>
        </inertial>
    </link>

    <joint name="upper_virtual_${id}_0_to_upper_virtual_${id}_1_0_joint" type="continuous">
        <parent link="upper_virtual_${id}_0_0_link"/>
        <child link="upper_virtual_${id}_1_0_link"/>
        <axis xyz="0 1 0"/>
        <limit effort="10.0" velocity="3.0"/>
        <dynamics damping="0.1" friction="0.01"/>
    </joint>

    <joint name="upper_virtual_${id}_0_to_upper_virtual_${id}_1_1_joint" type="continuous">
        <parent link="upper_virtual_${id}_0_1_link"/>
        <child link="upper_virtual_${id}_1_1_link"/>
        <axis xyz="0 1 0"/>
        <limit effort="10.0" velocity="3.0"/>
        <dynamics damping="0.1" friction="0.01"/>
    </joint>

    <joint name="upper_virtual_${id}_1_to_connector_${id}_0_link_joint" type="continuous">
        <parent link="upper_virtual_${id}_1_0_link"/>
        <child link="connector_${id}_0_link"/>
        <axis xyz="0 0 1"/>
        <limit effort="10.0" velocity="3.0"/>
        <dynamics damping="0.1" friction="0.01"/>
    </joint>

    <joint name="upper_virtual_${id}_1_to_connector_${id}_1_link_joint" type="continuous">
        <parent link="upper_virtual_${id}_1_1_link"/>
        <child link="connector_${id}_1_link"/>
        <axis xyz="0 0 1"/>
        <limit effort="10.0" velocity="3.0"/>
        <dynamics damping="0.1" friction="0.01"/>
    </joint>

    




    <link name="lower_virtual_${id}_0_0_link">
        <inertial>
            <mass value="0.001"/>
            <inertia ixx="1e-6" ixy="0" ixz="0" iyy="1e-6" iyz="0" izz="1e-6"/>
        </inertial>
    </link>

    <link name="lower_virtual_${id}_0_1_link">
        <inertial>
            <mass value="0.001"/>
            <inertia ixx="1e-6" ixy="0" ixz="0" iyy="1e-6" iyz="0" izz="1e-6"/>
        </inertial>
    </link>

    <joint name="connector_${id}_0_link_to_lower_virtual_${id}_0_0_joint" type="revolute">
        <parent link="connector_${id}_0_link"/>
        <child link="lower_virtual_${id}_0_0_link"/>
        <origin xyz="0 0 ${-lower_ball_screw_z}" rpy="0 0 0"/> 
        <axis xyz="1 0 0"/>
        <limit lower="-1.74" upper="1.74" effort="10.0" velocity="3.0"/>
        <dynamics damping="0.1" friction="0.01"/>
    </joint>

    <joint name="connector_${id}_1_link_to_lower_virtual_${id}_0_1_joint" type="revolute">
        <parent link="connector_${id}_1_link"/>
        <child link="lower_virtual_${id}_0_1_link"/>
        <origin xyz="0 0 ${-lower_ball_screw_z}" rpy="0 0 0"/> 
        <axis xyz="1 0 0"/>
        <limit lower="-1.74" upper="1.74" effort="10.0" velocity="3.0"/>
        <dynamics damping="0.1" friction="0.01"/>
    </joint>

    <link name="lower_virtual_${id}_1_0_link">
        <inertial>
            <mass value="0.001"/>
            <inertia ixx="1e-6" ixy="0" ixz="0" iyy="1e-6" iyz="0" izz="1e-6"/>
        </inertial>
    </link>

    <link name="lower_virtual_${id}_1_1_link">
        <inertial>
            <mass value="0.001"/>
            <inertia ixx="1e-6" ixy="0" ixz="0" iyy="1e-6" iyz="0" izz="1e-6"/>
        </inertial>
    </link>

    <joint name="lower_virtual_${id}_0_0_to_lower_virtual_${id}_1_0_joint" type="revolute">
        <parent link="lower_virtual_${id}_0_0_link"/>
        <child link="lower_virtual_${id}_1_0_link"/>
        <origin xyz="0 0 0" rpy="0 0 0"/> 
        <axis xyz="0 1 0"/>
        <limit lower="-1.74" upper="1.74" effort="10.0" velocity="3.0"/>
        <dynamics damping="0.1" friction="0.01"/>
    </joint>

    <joint name="lower_virtual_${id}_0_1_to_lower_virtual_${id}_1_1_joint" type="revolute">
        <parent link="lower_virtual_${id}_0_1_link"/>
        <child link="lower_virtual_${id}_1_1_link"/>
        <origin xyz="0 0 0" rpy="0 0 0"/> 
        <axis xyz="0 1 0"/>
        <limit lower="-1.74" upper="1.74" effort="10.0" velocity="3.0"/>
        <dynamics damping="0.1" friction="0.01"/>
    </joint>

    <link name="lower_virtual_${id}_2_0_link">
        <inertial>
            <mass value="0.001"/>
            <inertia ixx="1e-6" ixy="0" ixz="0" iyy="1e-6" iyz="0" izz="1e-6"/>
        </inertial>
    </link>

    <link name="lower_virtual_${id}_2_1_link">
        <inertial>
            <mass value="0.001"/>
            <inertia ixx="1e-6" ixy="0" ixz="0" iyy="1e-6" iyz="0" izz="1e-6"/>
        </inertial>
    </link>

    <joint name="lower_virtual_${id}_1_0_to_lower_virtual_${id}_2_0_joint" type="revolute">
        <parent link="lower_virtual_${id}_1_0_link"/>
        <child link="lower_virtual_${id}_2_0_link"/>
        <origin xyz="0 0 0" rpy="0 0 0"/> 
        <axis xyz="0 0 1"/>
        <limit lower="-1.74" upper="1.74" effort="10.0" velocity="3.0"/>
        <dynamics damping="0.1" friction="0.01"/>
    </joint>

    <joint name="lower_virtual_${id}_1_1_to_lower_virtual_${id}_2_1_joint" type="revolute">
        <parent link="lower_virtual_${id}_1_1_link"/>
        <child link="lower_virtual_${id}_2_1_link"/>
        <origin xyz="0 0 0" rpy="0 0 0"/> 
        <axis xyz="0 0 1"/>
        <limit lower="-1.74" upper="1.74" effort="10.0" velocity="3.0"/>
        <dynamics damping="0.1" friction="0.01"/>
    </joint>

</xacro:macro>

</robot>