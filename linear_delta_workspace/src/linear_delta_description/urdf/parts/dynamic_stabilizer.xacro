<?xml version="1.0"?>
<robot xmlns:xacro="http://www.ros.org/wiki/xacro">

<xacro:macro name="dynamic_stabilizer" params="id">
        
    <link name="dynamic_stabilizer_${id}_link">
        
        <visual>
            <origin xyz="0.0 0.0 0.0" rpy="0.0 0.0 0.0"/>
            <geometry>
                <mesh filename="package://linear_delta_description/meshes/dynamic_stabilizer.stl" scale="0.001 0.001 0.001"/>
            </geometry>
            <material name="color_12"/>
        </visual>

        <collision>
            <origin xyz="0.0 0.0 0.0" rpy="0.0 0.0 0.0"/>
            <geometry>
                <mesh filename="package://linear_delta_description/meshes/dynamic_stabilizer.stl" scale="0.001 0.001 0.001"/>
            </geometry>
        </collision>

        <inertial>
            <origin xyz="0.0 0.0 0.0" rpy="0.0 0.0 0.0"/>
            <mass value="${dynamic_stabilizer_mass}"/>
            <inertia ixx="0.001" ixy="0" ixz="0" iyy="0.001" iyz="0" izz="0.001"/>
        </inertial>
        
    </link>

    <joint name="rod_${id}_to_dynamic_stabilizer_${id}_joint" type="prismatic">
        <origin xyz="${dynamic_stabilizer_x} ${dynamic_stabilizer_y} 0.0" rpy="0.0 0.0 0.0"/>
        <parent link="rod_${id}_link"/>
        <child link="dynamic_stabilizer_${id}_link"/>
        <axis xyz="0.0 0.0 1.0"/>
        <limit lower="-0.04" upper="1.0" effort="150.0" velocity="2.0"/>
        <dynamics damping="1.0" friction="0.5"/>
    </joint>

</xacro:macro>

</robot>